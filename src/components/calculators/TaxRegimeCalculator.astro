---
import InputField from '../InputField.astro';
---

<div class="lg:col-span-6 space-y-6">
  <!-- Inputs -->
  <InputField id="annualIncome" label="Gross Annual Income (All Sources)" prefix="₹" value={1000000} type="number" />
  
  <div class="border-t border-vercel-gray-medium pt-4 space-y-4">
    <h3 class="text-xs font-bold text-white uppercase tracking-wider">Old Regime Deductions</h3>
    <InputField id="deduction80C" label="Section 80C (EPF, PPF, LIC, ELSS)" prefix="₹" value={150000} type="number" />
    <InputField id="deduction80D" label="Section 80D (Health Insurance Premium)" prefix="₹" value={250000} type="number" />
    <InputField id="hraExemption" label="Section 10(13A) (HRA Exemption)" prefix="₹" value={50000} type="number" />
    <InputField id="homeLoanInterest" label="Section 24(b) (Home Loan Interest)" prefix="₹" value={0} type="number" />
    <InputField id="otherDeductions" label="Other Deductions (80TTA, 80G, etc.)" prefix="₹" value={0} type="number" />
  </div>
</div>

<!-- Outputs -->
<div class="lg:col-span-6 border border-vercel-gray-medium bg-vercel-gray-dark rounded-xs p-6 space-y-6">
  <div>
    <h3 class="text-xs uppercase tracking-wider text-ink-faint">Tax Advice & Savings</h3>
    <div id="result-recommendation" class="text-2xl font-extrabold text-white mt-1">Recommended: New Regime</div>
    <div class="text-xs text-ink-muted mt-1">
      You save <span id="result-savings" class="font-mono text-white">₹15,600</span> annually using this regime.
    </div>
  </div>
  
  <div class="grid grid-cols-2 gap-4 border-t border-vercel-gray-medium pt-4 text-xs">
    <!-- Old Regime column -->
    <div class="space-y-3 border-r border-vercel-gray-medium pr-4">
      <h4 class="font-bold text-white uppercase text-[10px] tracking-wider">Old Tax Regime</h4>
      <div>
        <span class="text-ink-muted block text-[10px]">Taxable Income</span>
        <span id="result-old-taxable" class="text-white font-mono font-semibold">₹5,75,000</span>
      </div>
      <div>
        <span class="text-ink-muted block text-[10px]">Total Annual Tax</span>
        <span id="result-old-tax" class="text-red-500 font-mono font-semibold">₹28,600</span>
      </div>
    </div>

    <!-- New Regime column -->
    <div class="space-y-3 pl-2">
      <h4 class="font-bold text-white uppercase text-[10px] tracking-wider">New Tax Regime</h4>
      <div>
        <span class="text-ink-muted block text-[10px]">Taxable Income</span>
        <span id="result-new-taxable" class="text-white font-mono font-semibold">₹9,25,000</span>
      </div>
      <div>
        <span class="text-ink-muted block text-[10px]">Total Annual Tax</span>
        <span id="result-new-tax" class="text-red-500 font-mono font-semibold">₹13,000</span>
      </div>
    </div>
  </div>

  <div class="pt-2">
    <button 
      id="copy-btn" 
      class="w-full py-2 px-4 rounded-xs border border-vercel-gray-light bg-vercel-gray-medium text-xs font-semibold text-white hover:bg-vercel-gray-light hover:border-white transition-all cursor-pointer"
    >
      Copy Comparison Report
    </button>
  </div>
</div>

<script>
  import { calculateTaxRegime } from '../CalcLogic/tax-regime';

  const formatter = new Intl.NumberFormat('en-IN', {
    style: 'decimal',
    maximumFractionDigits: 0
  });

  const formatINR = (val: number) => `₹${formatter.format(val)}`;

  // Bind elements
  const incomeInput = document.getElementById('annualIncome') as HTMLInputElement;
  const dec80CInput = document.getElementById('deduction80C') as HTMLInputElement;
  const dec80DInput = document.getElementById('deduction80D') as HTMLInputElement;
  const hraInput = document.getElementById('hraExemption') as HTMLInputElement;
  const loanInput = document.getElementById('homeLoanInterest') as HTMLInputElement;
  const otherInput = document.getElementById('otherDeductions') as HTMLInputElement;

  const resultRec = document.getElementById('result-recommendation') as HTMLDivElement;
  const resultSavings = document.getElementById('result-savings') as HTMLSpanElement;
  const resultOldTaxable = document.getElementById('result-old-taxable') as HTMLSpanElement;
  const resultOldTax = document.getElementById('result-old-tax') as HTMLSpanElement;
  const resultNewTaxable = document.getElementById('result-new-taxable') as HTMLSpanElement;
  const resultNewTax = document.getElementById('result-new-tax') as HTMLSpanElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;

  function updateCalculations() {
    if (!incomeInput || !dec80CInput || !dec80DInput || !hraInput || !loanInput || !otherInput) return;

    const annualIncome = parseFloat(incomeInput.value) || 0;
    const deduction80C = parseFloat(dec80CInput.value) || 0;
    const deduction80D = parseFloat(dec80DInput.value) || 0;
    const hraExemption = parseFloat(hraInput.value) || 0;
    const homeLoanInterest = parseFloat(loanInput.value) || 0;
    const otherDeductions = parseFloat(otherInput.value) || 0;

    const result = calculateTaxRegime({
      annualIncome,
      deduction80C,
      deduction80D,
      hraExemption,
      homeLoanInterest,
      otherDeductions
    });

    // Update DOM
    if (resultRec) resultRec.textContent = `Recommended: ${result.recommendedRegime} Regime`;
    if (resultSavings) resultSavings.textContent = formatINR(result.netSavings);
    if (resultOldTaxable) resultOldTaxable.textContent = formatINR(result.oldRegimeTaxable);
    if (resultOldTax) resultOldTax.textContent = formatINR(result.oldRegimeTax);
    if (resultNewTaxable) resultNewTaxable.textContent = formatINR(result.newRegimeTaxable);
    if (resultNewTax) resultNewTax.textContent = formatINR(result.newRegimeTax);
  }

  // Event Listeners
  [incomeInput, dec80CInput, dec80DInput, hraInput, loanInput, otherInput].forEach(el => {
    if (el) {
      el.addEventListener('input', updateCalculations);
      el.addEventListener('change', updateCalculations);
    }
  });

  // Copy action
  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      if (resultRec && resultSavings) {
        const text = `${resultRec.textContent}. Savings: ${resultSavings.textContent}/year. (Old Tax: ${resultOldTax.textContent}, New Tax: ${resultNewTax.textContent})`;
        navigator.clipboard.writeText(text).then(() => {
          const originalText = copyBtn.textContent;
          copyBtn.textContent = 'Copied!';
          copyBtn.classList.add('border-vercel-blue');
          setTimeout(() => {
            copyBtn.textContent = originalText;
            copyBtn.classList.remove('border-vercel-blue');
          }, 1500);
        });
      }
    });
  }

  // Initial update
  updateCalculations();
</script>
