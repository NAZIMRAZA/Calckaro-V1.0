---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = "CalcKaro — India's Calculator Hub | Fast, Free, Built for Bharat",
  description = "India's dedicated calculator hub. Free online calculators for GST, EMI, SIP, In-Hand Salary, Notice Period, FD, and more, customized for Bharat.",
  canonicalUrl = Astro.url.href
} = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full bg-vercel-black text-white">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO & Metadata -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Icons & Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      if (theme === 'light') {
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.remove('light');
      }
    </script>
  </head>
  <body class="h-full flex flex-col justify-between bg-vercel-black text-white selection:bg-vercel-blue selection:text-white">
    <!-- Header -->
    <header class="sticky top-0 z-40 w-full border-b border-vercel-gray-medium bg-vercel-black/80 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <!-- Logo -->
        <div class="flex items-center gap-6">
          <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight text-white hover:text-vercel-blue transition-colors">
            <span class="text-vercel-blue font-mono">&gt;_</span>Calc<span class="font-light">Karo</span>
          </a>
          
          <!-- Desktop Navigation -->
          <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-ink-muted">
            <a href="/about" class="hover:text-white transition-colors">About Us</a>
            <a href="/faq" class="hover:text-white transition-colors">FAQ</a>
            <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
            <a href="/terms" class="hover:text-white transition-colors">Terms & Conditions</a>
            <a href="/contact" class="hover:text-white transition-colors">Contact Us</a>
          </nav>
        </div>

        <!-- Right navigation / search placeholder -->
        <div class="flex items-center gap-3">
          <div class="relative w-40 sm:w-48">
            <input 
              type="text" 
              placeholder="Search..." 
              disabled
              class="w-full rounded-xs border border-vercel-gray-medium bg-vercel-gray-dark px-3 py-1.5 text-xs text-ink-muted outline-none transition-all placeholder:text-ink-faint focus:border-vercel-blue"
            />
          </div>
          
          <!-- Theme Toggle -->
          <button id="theme-toggle" class="p-1.5 rounded-xs border border-vercel-gray-medium bg-vercel-gray-dark text-ink-muted hover:text-white transition-colors cursor-pointer" aria-label="Toggle theme">
            <svg id="theme-toggle-sun" class="w-3.5 h-3.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
            </svg>
            <svg id="theme-toggle-moon" class="w-3.5 h-3.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow">
      <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <slot />
      </div>
    </main>

    <!-- Footer -->
    <footer class="w-full border-t border-vercel-gray-medium bg-vercel-black py-8">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-ink-muted">
          <div>
            &copy; {new Date().getFullYear()} CalcKaro. Built for Bharat.
          </div>
          <div class="flex gap-4">
            <a href="/about" class="hover:text-white transition-colors">About</a>
            <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
            <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>
    <script>
      const toggleBtn = document.getElementById('theme-toggle');
      const sunIcon = document.getElementById('theme-toggle-sun');
      const moonIcon = document.getElementById('theme-toggle-moon');

      function updateThemeIcons() {
        const isLight = document.documentElement.classList.contains('light');
        if (isLight) {
          sunIcon?.classList.remove('hidden');
          moonIcon?.classList.add('hidden');
        } else {
          sunIcon?.classList.add('hidden');
          moonIcon?.classList.remove('hidden');
        }
      }

      toggleBtn?.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        updateThemeIcons();
      });

      // Initial update
      updateThemeIcons();
    </script>
  </body>
</html>
