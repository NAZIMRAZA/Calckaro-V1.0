---
import Base from '../../layouts/Base.astro';
import calculators from '../../data/calculators.json';

export async function getStaticPaths() {
  const categories = [
    {
      slug: 'finance',
      title: 'Finance Hub',
      subtitle: 'Complete suite of take-home salary, GST, TDS, HRA tax exemption, and gratuity estimators.',
      jsonCategory: 'salaried-professional'
    },
    {
      slug: 'student',
      title: 'Student & Academic Hub',
      subtitle: 'Grade conversion engines, CGPA calculators, and board exam percentage checkers.',
      jsonCategory: 'student'
    },
    {
      slug: 'crypto',
      title: 'Crypto Toolkit',
      subtitle: 'USDT pricing checkers, P2P margins, and crypto taxation estimators for India.',
      jsonCategory: 'crypto'
    },
    {
      slug: 'investment',
      title: 'Loans & Investing Hub',
      subtitle: 'FD interest grids, mutual fund SIP projections, and bank EMI payment schedules.',
      jsonCategory: 'investment'
    }
  ];

  return categories.map(cat => ({
    params: { category: cat.slug },
    props: { cat }
  }));
}

const { category } = Astro.params;
const { cat } = Astro.props;

// Filter calculators matching the category mapping
const matchedCalcs = calculators.filter(calc => calc.category === cat.jsonCategory);
---

<Base title={`${cat.title} — CalcKaro`} description={cat.subtitle}>
  <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8 space-y-12">
    <!-- Header -->
    <div class="border-b border-vercel-gray-medium pb-6">
      <div class="text-xs font-semibold text-vercel-blue uppercase tracking-widest mb-1">Hub Directory</div>
      <h1 class="text-4xl font-extrabold text-white tracking-tight">{cat.title}</h1>
      <p class="text-sm text-ink-muted mt-2 max-w-3xl leading-relaxed">{cat.subtitle}</p>
    </div>

    <!-- Calculators List/Grid -->
    {matchedCalcs.length > 0 ? (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {matchedCalcs.map(calc => (
          <a 
            href={`/finance/${calc.slug}`} 
            class="group block border border-vercel-gray-medium bg-vercel-gray-dark hover:bg-vercel-gray-medium hover:border-vercel-blue rounded-xs p-6 transition-all duration-200"
          >
            <h3 class="text-base font-bold text-white group-hover:text-vercel-blue transition-colors mb-2">
              {calc.name}
            </h3>
            <p class="text-xs text-ink-muted leading-relaxed line-clamp-3">
              {calc.metaDescription}
            </p>
            <div class="text-[10px] font-mono text-vercel-blue mt-4 flex items-center gap-1 font-semibold">
              Open Calculator 
              <span class="transform group-hover:translate-x-1 transition-transform">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="border border-vercel-gray-medium rounded-xs p-12 text-center bg-vercel-gray-dark max-w-xl mx-auto space-y-4">
        <div class="text-2xl font-bold text-white">We are building this Hub!</div>
        <p class="text-xs text-ink-muted leading-relaxed">
          Our development team is currently coding and verifying the mathematical models for the {cat.title} category. Check back soon for brand new tools.
        </p>
        <div class="pt-4">
          <a 
            href="/contact" 
            class="inline-block py-2 px-6 rounded-xs border border-vercel-gray-light bg-vercel-gray-medium text-xs font-semibold text-white hover:bg-vercel-gray-light hover:border-white transition-all"
          >
            Request a Calculator
          </a>
        </div>
      </div>
    )}

    <!-- Back to Hubs -->
    <div class="pt-6 border-t border-vercel-gray-medium text-xs">
      <a href="/" class="text-ink-muted hover:text-white transition-colors flex items-center gap-1">
        &larr; Back to all Categories
      </a>
    </div>
  </div>
</Base>
