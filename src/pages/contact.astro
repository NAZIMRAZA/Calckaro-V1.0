---
import Base from '../layouts/Base.astro';
---

<Base title="Contact Us — CalcKaro" description="Get in touch with the team at CalcKaro.">
  <div class="max-w-3xl mx-auto space-y-8 py-8">
    <div class="border-b border-vercel-gray-medium pb-4">
      <h1 class="text-3xl font-extrabold text-white tracking-tight">Contact Us</h1>
      <p class="text-sm text-ink-muted mt-2">Have feedback, suggestions, or want to report an issue? We'd love to hear from you.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <!-- Contact Information -->
      <div class="space-y-6 text-xs text-ink-muted leading-relaxed">
        <p>
          We are committed to making CalcKaro the most helpful calculator hub for India. If you find any calculation mismatches, want to request a new calculator, or have business inquiries, reach out to us.
        </p>
        
        <div class="space-y-3 pt-4 border-t border-vercel-gray-medium">
          <div>
            <strong class="text-white">Email:</strong>
            <p class="mt-0.5">support@calckaro.com</p>
          </div>
          <div>
            <strong class="text-white">Office Location:</strong>
            <p class="mt-0.5">Bengaluru, Karnataka, India</p>
          </div>
        </div>
      </div>

      <!-- Contact Form Placeholder -->
      <div class="border border-vercel-gray-medium rounded-xs p-6 bg-vercel-gray-dark space-y-4">
        <h3 class="text-sm font-bold text-white">Send a Message</h3>
        <form class="space-y-3" onsubmit="event.preventDefault(); alert('Message sent successfully!');">
          <div class="space-y-1">
            <label class="block text-[10px] text-white">Your Name</label>
            <input type="text" required class="w-full bg-vercel-black border border-vercel-gray-medium rounded-xs p-2 text-xs text-white outline-none focus:border-vercel-blue" />
          </div>
          <div class="space-y-1">
            <label class="block text-[10px] text-white">Email Address</label>
            <input type="email" required class="w-full bg-vercel-black border border-vercel-gray-medium rounded-xs p-2 text-xs text-white outline-none focus:border-vercel-blue" />
          </div>
          <div class="space-y-1">
            <label class="block text-[10px] text-white">Message</label>
            <textarea required rows="3" class="w-full bg-vercel-black border border-vercel-gray-medium rounded-xs p-2 text-xs text-white outline-none focus:border-vercel-blue"></textarea>
          </div>
          <button type="submit" class="w-full py-2 px-4 rounded-xs border border-vercel-gray-light bg-vercel-gray-medium text-xs font-semibold text-white hover:bg-vercel-gray-light hover:border-white transition-all cursor-pointer">
            Send Message
          </button>
        </form>
      </div>

    </div>
  </div>
</Base>
