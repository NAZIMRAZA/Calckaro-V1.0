---
import calculators from '../data/calculators.json';

export async function getStaticPaths() {
  return calculators.map(calc => ({
    params: { calculator: calc.slug },
    props: { slug: calc.slug }
  }));
}

const { slug } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="refresh" content={`0;url=/finance/${slug}`} />
  <title>Redirecting...</title>
  <link rel="canonical" href={`/finance/${slug}`} />
</head>
<body>
  <p>Redirecting to <a href={`/finance/${slug}`}>/finance/{slug}</a>...</p>
</body>
</html>
